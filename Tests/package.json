{
  "type": "module",
  "scripts": {
    "watchTS": "dotnet fable watch --outDir ts --lang typescript ../Src/Str.fsproj --run tsc" ,

    "buildTS": "dotnet fable --outDir ts --noCache  --lang typescript ../Src/Str.fsproj --silent --run tsc" ,
    "pretest": "dotnet fable --outDir js --noCache ",
    "test": "mocha js",
    "testTS": "mocha js && npm run buildTS"
  },

  "devDependencies": {
    "mocha": "^11.7.5",
    "typescript": "^6.0.2"
  }
}
